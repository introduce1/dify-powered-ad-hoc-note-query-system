# 服务器配置
APP_HOST=0.0.0.0
APP_PORT=8888
APP_DEBUG=false
SECRET_KEY=your-secret-key-here

# MySQL 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=record_db

# Dify API
DIFY_API_BASE=http://localhost/v1

# 工作流配置 - 随记随查
WF_SUIJI_ID=your_workflow_id
WF_SUIJI_KEY=app-your_api_key

# 工作流配置 - 多轮对话
WF_DUOLUN_ID=your_workflow_id
WF_DUOLUN_KEY=app-your_api_key

# 工作流配置 - 生产记录查询
WF_SHENGCHAN_ID=your_workflow_id
WF_SHENGCHAN_KEY=app-your_api_key

# 流式传输
STREAM_TIMEOUT=300
DEBUG_STREAM=1
